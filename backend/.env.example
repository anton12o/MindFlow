# MindFlow Backend — Variáveis de Ambiente
# Copie este arquivo como .env e ajuste os valores

# Origens permitidas para CORS (separadas por vírgula se múltiplas)
CORS_ORIGINS=http://localhost:5173

# Caminho personalizado do banco SQLite (opcional — padrão: backend/mindflow.db)
# MFLOW_DB_PATH=C:/Users/MeuNome/Documents/mindflow.db

# Modo journal do SQLite (opcional — padrão: WAL, use DELETE se estiver em cloud sync)
# MFLOW_JOURNAL_MODE=DELETE